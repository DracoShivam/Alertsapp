# Discord Notification Setup
# Paste your Discord channel webhook URL here
DISCORD_WEBHOOK_URL=your_discord_webhook_url_here

# Email Notification Setup (SMTP)
# Paste your sender email and password (for Gmail, use an App Password)
SMTP_USER=sender_email@gmail.com
SMTP_PASSWORD=your_email_app_password

# WhatsApp Notification Setup (Twilio)
# Twilio credentials
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token
